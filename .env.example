# ============================================================================
# Infrastructure-only env vars
# All application config (Stripe, Supabase, Twilio, Email, AI, etc.) is
# managed via the Admin → Settings panel and stored in the database.
# ============================================================================

# Database (local Docker PostgreSQL - see docker-compose.yml)
DATABASE_URL=postgresql://derma:derma_local_pwd@localhost:5433/dermaconsent

# Auth (required — backend crashes without AUTH_SECRET)
AUTH_SECRET=your-secret-min-32-chars-change-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Backend
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Platform encryption (required in production for encrypting secrets in PlatformConfig DB)
PLATFORM_ENCRYPTION_KEY=

# Platform admin bootstrap (auto-created on first deploy via prisma/bootstrap.ts)
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# Sentry (optional — error tracking, strongly recommended for production)
SENTRY_DSN=

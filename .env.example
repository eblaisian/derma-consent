# Database (local Docker PostgreSQL - see docker-compose.yml)
DATABASE_URL=postgresql://derma:derma_local_pwd@localhost:5433/dermaconsent

# Auth (required — backend crashes without AUTH_SECRET)
AUTH_SECRET=your-secret-min-32-chars-change-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Backend
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# Platform encryption (required in production for encrypting secrets in PlatformConfig DB)
PLATFORM_ENCRYPTION_KEY=

# Platform admin bootstrap (auto-created on first deploy via prisma/bootstrap.ts)
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# Sentry (optional — error tracking, strongly recommended for production)
SENTRY_DSN=

# Supabase (optional — only needed for PDF/photo storage in production)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Stripe (optional — leave empty for local dev without payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=5

# Email / SMTP (optional — for sending transactional emails)
SMTP_USER=
SMTP_PASSWORD=

# Twilio (optional — for SMS/WhatsApp consent delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI (OpenAI or Ollama)
# For production: set OPENAI_API_KEY, leave OPENAI_BASE_URL empty (defaults to OpenAI)
# For local dev with Ollama: set OPENAI_BASE_URL, leave OPENAI_API_KEY empty
#   brew install ollama && ollama serve && ollama pull llama3.1
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.1

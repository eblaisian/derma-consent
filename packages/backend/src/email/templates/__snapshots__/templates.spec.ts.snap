                  <td align="left" style="font-size: 15px; font-weight: 600; color: #0f172a; letter-spacing: -0.01em;">DermaConsent</td>
                  
                </tr>
              </table>
            </td>
          </tr>
        </table>

        <!-- Card -->
        <table role="presentation" class="email-card" width="560" cellpadding="0" cellspacing="0" style="max-width: 560px; width: 100%; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px;">
          <tr>
            <td style="padding: 40px 48px; text-align: left;" class="email-body-text">
              
  <h1 style="font-size: 22px; font-weight: 700; color: #0f172a; margin: 0 0 16px; letter-spacing: -0.02em;">Bienvenue sur DermaConsent !</h1>
  <p style="font-size: 16px; line-height: 1.6; color: #374151; margin: 0 0 8px;">Bonjour Test User,</p>
  <p style="font-size: 16px; line-height: 1.6; color: #374151; margin: 0 0 24px;">Votre compte a été créé avec succès. Voici ce que vous pouvez faire :</p>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 8px;">
    
    <tr>
      <td style="padding: 12px 16px; background-color: #f9fafb; border-radius: 4px;">
        <p style="font-size: 14px; font-weight: 600; color: #0f172a; margin: 0 0 2px;">Formulaires de consentement</p>
        <p style="font-size: 13px; color: #6b7280; margin: 0;">Créer, envoyer et gérer numériquement</p>
      </td>
    </tr>
    <tr><td style="height: 8px;"></td></tr>
    <tr>
      <td style="padding: 12px 16px; background-color: #f9fafb; border-radius: 4px;">
        <p style="font-size: 14px; font-weight: 600; color: #0f172a; margin: 0 0 2px;">Données patients</p>
        <p style="font-size: 13px; color: #6b7280; margin: 0;">Stocker avec chiffrement de bout en bout</p>
      </td>
    </tr>
    <tr><td style="height: 8px;"></td></tr>
    <tr>
      <td style="padding: 12px 16px; background-color: #f9fafb; border-radius: 4px;">
        <p style="font-size: 14px; font-weight: 600; color: #0f172a; margin: 0 0 2px;">Archivage RGPD</p>
        <p style="font-size: 13px; color: #6b7280; margin: 0;">Documenter et exporter en conformité</p>
      </td>
    </tr>
    <tr><td style="height: 8px;"></td></tr>
  </table>
  <table role="presentation" cellpadding="0" cellspacing="0"  style="margin: 24px 0;">
    <tr>
      <td align="center" style="border-radius: 6px; background-color: #0f172a;">
        <a href="http://localhost:3000/dashboard" style="display: inline-block; background-color: #0f172a; color: #ffffff; padding: 14px 28px; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px; line-height: 1;">Aller au tableau de bord →</a>
      </td>
    </tr>
  </table>
  <p style="font-size: 13px; color: #9ca3af; margin: 0;">Des questions ? Répondez à cet e-mail.</p>
            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table role="presentation" class="email-footer" width="560" cellpadding="0" cellspacing="0" style="max-width: 560px; width: 100%;">
          <tr>
            <td style="padding: 20px 0 0; text-align: center;">
              <p style="color: #9ca3af; font-size: 12px; line-height: 1.5; margin: 0;">
                Envoyé via DermaConsent · <a href="https://consent.eblaisian.com/impressum" style="color: #9ca3af; text-decoration: underline;">Mentions légales</a>
              </p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>
</html>"
`;


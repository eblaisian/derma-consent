        <td>
          <span style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: #9ca3af;">الدور</span><br>
          <span style="display: inline-block; font-size: 13px; font-weight: 500; color: #374151; background-color: #f3f4f6; padding: 2px 10px; border-radius: 12px; margin-top: 4px;">مدير</span>
        </td>
      </tr>
    </table>
  
      </td>
    </tr>
  </table>

